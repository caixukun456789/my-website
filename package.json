{
  "name": "dongni-link-dock",
  "version": "1.0.0",
  "description": "Dongni Link Dock desktop app for native-feeling link and bookmark management.",
  "main": "desktop/main.cjs",
  "private": true,
  "scripts": {
    "desktop": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable",
    "check": "node --check script.js && node --check desktop/main.cjs"
  },
  "build": {
    "appId": "com.dongni.linkdock",
    "productName": "Dongni Link Dock",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "site-data.json",
      "assets/**/*",
      "desktop/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Dongni-Link-Dock-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  }
}
